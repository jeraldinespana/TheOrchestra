MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1802499015}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d57325059154af5438a7439a012f3426, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Alejandro
    text: Ah, another one. Sit down, sit down!
  - speakerName: Alejandro
    text: I am Alejandro. It's nice to see a new face.
  - speakerName: Alejandro
    text: I have been waiting for six months now...
  - speakerName: Alejandro
    text: ...all for my first audition.
  - speakerName: Alejandro
    text: They keep asking me for more documents.
  - speakerName: Alejandro
    text: It never seems like it's enough.
  - speakerName: Alejandro
    text: It's good to be thorough...
  - speakerName: Alejandro
    text: ...I guess.
  - speakerName: Alejandro
    text: You might be here a while.
  - speakerName: Alejandro
    text: Don't be surprised if you end up waiting years for a chance-
