--- !u!114 &1458289617
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1458289616}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d57325059154af5438a7439a012f3426, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Jing
    text: Do not let Alejandro scare you.
  - speakerName: Jing
    text: My name is Jing. It's my 4th time auditioning.
  - speakerName: Jing
    text: The conductor is not so bad.
  - speakerName: Jing
    text: He just wants to see that you really want this.
  - speakerName: Jing
    text: That you are deserving. He's a tough one, for sure.
  - speakerName: Jing
    text: Huh?
  - speakerName: Jing
    text: You're being called in?
  - speakerName: Jing
    text: So soon after your arrival?
  - speakerName: Jing
    text: Oh my...
  - speakerName: Jing
    text: Well, good luck then.
