--- !u!114 &294160506
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 294160504}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 23c52eaaafc180246bc7364dbb029bb3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  mainCamera: {fileID: 330585545}
  conductor: {fileID: 501796539}
  miniGame: {fileID: 836765746}
  failed1:
  - speakerName: Conductor
    text: Insufficient.
  - speakerName: Conductor
    text: Not what I was looking for at all, actually.
  - speakerName: Conductor
    text: You have completely missed the standard required for my orchestra.
  - speakerName: Conductor
    text: You may try again when I have time.
  failed2:
  - speakerName: Conductor
    text: Closer.
  - speakerName: Conductor
    text: But not close enough.
  - speakerName: Conductor
    text: The orchestra requires certainty...
  - speakerName: Conductor
    text: ...that you will always play your best.
  - speakerName: Conductor
    text: And your best,
  - speakerName: Conductor
    text: Well,
  - speakerName: Conductor
    text: It wasn't good enough.
  - speakerName: Conductor
    text: Come back when you really mean business.
  pass:
  - speakerName: Conductor
    text: ...
  - speakerName: Conductor
    text: Well...
  - speakerName: Conductor
    text: That was...
  - speakerName: Conductor
    text: Good.
  - speakerName: Conductor
    text: Welcome to the Orchestra....
  - speakerName: Conductor
    text: MY Orchestra.
  - speakerName: Conductor
    text: Remember, I can always remove you...
  - speakerName: Conductor
    text: If you fail to meet my standards.
  completeFail:
  - speakerName: Conductor
    text: The Orchestra has made its decision.
  - speakerName: Conductor
    text: Maybe next...year?
  - speakerName: Conductor
    text: Too bad.
  - speakerName: Conductor
    text: Go back to the waiting room.
  - speakerName: Conductor
    text: Until next time.
  auditionLines1:
  - speakerName: Conductor
    text: ....Next.
  - speakerName: Conductor
    text: You will play what is written.
  - speakerName: Conductor
    text: Nothing more....
  - speakerName: Conductor
    text: nothing less.
  - speakerName: Conductor
    text: Begin.
  auditionLines2:
  - speakerName: Conductor
    text: You again.
  - speakerName: Conductor
    text: How long has it been?
  - speakerName: Conductor
    text: Hmph...
  - speakerName: Conductor
    text: Let's hope you're ready this time.
  - speakerName: Conductor
    text: My standards have only increased since last time.
  - speakerName: Conductor
    text: Begin.
  auditionLines3:
  - speakerName: Conductor
    text: I'm surprised to see you.
  - speakerName: Conductor
    text: You've really returned?
  - speakerName: Conductor
    text: Most do not make it this far.
  - speakerName: Conductor
    text: They give up after a couple months.
  - speakerName: Conductor
    text: Maybe even years.
  - speakerName: Conductor
    text: Begin.
  finalWin:
  - speakerName: 
    text: Congratulations.
  - speakerName: 
    text: The Conductor has stamped your papers.
  - speakerName: 
    text: You are official now.
  - speakerName: 
    text: Just remember,
  - speakerName: 
    text: Alejandro and Jing...
  - speakerName: 
    text: are still waiting.
  - speakerName: 
    text: They play just as well as you do.
  - speakerName: 
    text: But luck hasn't given them the chance to prove it.
  - speakerName: 
    text: And there are so many like them.
  - speakerName: 
    text: There are as many as 15 million undocumented immigrants in the US.
  - speakerName: 
    text: Wishing to live the American dream.
  - speakerName: 
    text: Some have been waiting over 10 years.
  - speakerName: 
    text: Just for a chance.
  - speakerName: 
    text: Remember...
  - speakerName: 
    text: to extend kindness to others.
  - speakerName: 
    text: Thanks for playing!
  finalLoss:
  - speakerName: 
    text: The door closes.
  - speakerName: 
    text: You can audition next season...or maybe the one after.
  - speakerName: 
    text: Alejandro slides over to make room for you.
  - speakerName: 
    text: Jing is nowhere to be found.
  - speakerName: 
    text: You hear they made the orchestra some time ago.
  - speakerName: 
    text: Alejandro waits for his first audition...
  - speakerName: 
    text: as you wait for yours.
  - speakerName: 
    text: And there are so many like you.
  - speakerName: 
    text: There are as many as 15 million undocumented immigrants in the US.
  - speakerName: 
    text: Wishing to live the American dream.
  - speakerName: 
    text: Some have been waiting over 10 years.
  - speakerName: 
    text: And will continue to wait.
  - speakerName: 
    text: Just for a chance.
  - speakerName: 
    text: Remember...
  - speakerName: 
    text: to extend kindness to others.
  - speakerName: 
    text: Thanks for playing!
  EndScreen: {fileID: 1559536866}
  dialoguePanel: {fileID: 1183711423}
  auditionAttempts: 0
  endScreenGroupWin: {fileID: 1559536871}
  endScreenGroupLose: {fileID: 1661786902}
